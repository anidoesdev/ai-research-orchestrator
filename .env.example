PG_USER=admin
PG_PASSWORD=postpass
PG_DB=research_memory
PG_HOST=127.0.0.1
PG_PORT=5432

# If you run Redis in Docker/another host, set this accordingly.
REDIS_URL=redis://localhost:6379

# Optional: keep embeddings consistent with pgvector column dimension.
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

